import java.util.*;
class PalindromeString{
    public static void main(String[] args){
        String t="malayalam";
        int n=t.length();
        int i=0;
        int j=n-1;
        while(i<=j){
            if(t.charAt(i)==t.charAt(j)){
                i++;
                j--;
            }
            else{
                System.out.println("Not palindrome");
                  return;
            } 
        }
        System.out.println("Palindrome");
    }
}
        
